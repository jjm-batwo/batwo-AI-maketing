<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ '월간' if data.report_meta.get('report_type') == 'monthly' else '주간' }} 마케팅 리포트 - {{ data.report_meta.brand_name }}</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;600;700;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
/* ===== CSS VARIABLES - LIGHT MODE ===== */
:root {
  --bg-primary: #F6F7FB;
  --bg-secondary: #EDEEF4;
  --bg-card: #FFFFFF;
  --bg-card-hover: #F9F9FD;
  --border: #E2E4ED;
  --border-active: #C8CBDB;
  --text-primary: #1A1D2E;
  --text-secondary: #5A5E76;
  --text-muted: #8B8FA8;
  --accent-blue: #3B6FE0;
  --accent-blue-dim: rgba(59,111,224,0.10);
  --accent-green: #16A370;
  --accent-green-dim: rgba(22,163,112,0.09);
  --accent-red: #E04545;
  --accent-red-dim: rgba(224,69,69,0.08);
  --accent-yellow: #D49A08;
  --accent-yellow-dim: rgba(212,154,8,0.09);
  --accent-purple: #7C5CDB;
  --accent-purple-dim: rgba(124,92,219,0.10);
  --gradient-brand: linear-gradient(135deg, #3B6FE0 0%, #7C5CDB 100%);
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 16px;
}

* { margin:0; padding:0; box-sizing:border-box; }

body {
  font-family: 'Noto Sans KR', sans-serif;
  background: var(--bg-primary);
  color: var(--text-primary);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  word-break: keep-all;
  overflow-wrap: break-word;
}

.report-container { max-width: 1200px; margin: 0 auto; padding: 40px 24px 80px; }

/* ===== HEADER ===== */
.report-header { text-align: center; padding: 60px 0 48px; position: relative; }
.report-header::before {
  content: ''; position: absolute; top: -40px; left: 50%; transform: translateX(-50%);
  width: 600px; height: 600px;
  background: radial-gradient(circle, rgba(59,111,224,0.06) 0%, transparent 70%);
  pointer-events: none;
}
.brand-badge {
  display: inline-flex; align-items: center; gap: 8px; padding: 6px 16px;
  background: var(--accent-blue-dim); border: 1px solid rgba(59,111,224,0.3);
  border-radius: 100px; font-size: 12px; font-weight: 600; color: var(--accent-blue);
  letter-spacing: 0.5px; text-transform: uppercase; margin-bottom: 20px;
}
.brand-badge .dot { width: 6px; height: 6px; background: var(--accent-blue); border-radius: 50%; }
.report-title {
  font-size: 42px; font-weight: 900; letter-spacing: -1px;
  background: var(--gradient-brand); -webkit-background-clip: text;
  -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 12px;
}
.report-period { font-size: 16px; color: var(--text-secondary); }
.report-period span { color: var(--text-primary); font-weight: 600; }

/* ===== SECTION ===== */
.section { margin-top: 48px; }
.section-label {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 11px; font-weight: 700; letter-spacing: 1.5px;
  text-transform: uppercase; color: var(--text-muted); margin-bottom: 16px;
}
.section-label::before { content: ''; width: 16px; height: 2px; background: var(--gradient-brand); border-radius: 2px; }
.section-title { font-size: 24px; font-weight: 700; margin-bottom: 24px; }

/* ===== KPI CARDS ===== */
.kpi-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; }
.kpi-card {
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: var(--radius-lg); padding: 24px; overflow: hidden;
}
.kpi-card.highlight {
  border-color: rgba(59,111,224,0.18);
  background: linear-gradient(135deg, var(--bg-card) 0%, rgba(59,111,224,0.04) 100%);
}
.kpi-label { font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 12px; }
.kpi-value { font-family: 'JetBrains Mono', monospace; font-size: 22px; font-weight: 700; margin-bottom: 8px; line-height: 1.1; white-space: nowrap; }
.kpi-change { font-size: 13px; font-weight: 600; display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; border-radius: 6px; }
.kpi-change.up { color: var(--accent-green); background: var(--accent-green-dim); }
.kpi-change.down { color: var(--accent-red); background: var(--accent-red-dim); }

/* ===== CHART ===== */
.chart-container { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 28px; margin-bottom: 24px; }
.chart-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
.chart-title { font-size: 16px; font-weight: 600; }
.chart-legend { display: flex; gap: 16px; }
.legend-item { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--text-secondary); }
.legend-dot { width: 8px; height: 8px; border-radius: 50%; }
canvas#dailyChart { width: 100% !important; height: 280px !important; }

/* ===== TABLE ===== */
.data-table-wrapper { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; }
.data-table { width: 100%; border-collapse: collapse; font-size: 13px; }
.data-table thead th {
  padding: 14px 16px; text-align: left; font-weight: 600; font-size: 11px;
  text-transform: uppercase; letter-spacing: 0.8px; color: var(--text-muted);
  background: rgba(0,0,0,0.02); border-bottom: 1px solid var(--border);
}
.data-table thead th:not(:first-child) { text-align: right; }
.data-table tbody td {
  padding: 12px 16px; border-bottom: 1px solid rgba(0,0,0,0.05);
  color: var(--text-secondary); font-family: 'JetBrains Mono', monospace; font-size: 12px;
}
.data-table tbody td:not(:first-child) { text-align: right; }
.data-table tbody td:first-child { color: var(--text-primary); font-family: 'Noto Sans KR', sans-serif; font-weight: 500; }
.data-table tbody tr:last-child td { border-bottom: none; }

/* ===== CAMPAIGN ===== */
.campaign-grid { display: grid; gap: 16px; }
.campaign-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 24px; display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: center; }
.campaign-name { font-size: 15px; font-weight: 600; margin-bottom: 4px; }
.campaign-objective { font-size: 12px; color: var(--text-muted); }
.campaign-metrics { display: flex; gap: 24px; align-items: center; }
.campaign-metric { text-align: right; }
.campaign-metric-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.6px; color: var(--text-muted); margin-bottom: 2px; }
.campaign-metric-value { font-family: 'JetBrains Mono', monospace; font-size: 14px; font-weight: 600; }
.status-badge {
  display: inline-flex; align-items: center; gap: 5px; padding: 4px 10px;
  border-radius: 6px; font-size: 10px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;
}
.status-badge.active { background: var(--accent-green-dim); color: var(--accent-green); }
.status-badge.active::before { content: ''; width: 5px; height: 5px; background: var(--accent-green); border-radius: 50%; }
.status-badge.paused { background: var(--accent-yellow-dim); color: var(--accent-yellow); }

/* ===== FATIGUE ===== */
.fatigue-grid { display: grid; gap: 16px; }
.fatigue-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 24px; display: flex; gap: 20px; align-items: flex-start; }
.fatigue-indicator { width: 4px; border-radius: 4px; align-self: stretch; flex-shrink: 0; }
.fatigue-indicator.critical { background: var(--accent-red); }
.fatigue-indicator.warning { background: var(--accent-yellow); }
.fatigue-indicator.healthy { background: var(--accent-green); }
.fatigue-level { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; padding: 3px 10px; border-radius: 6px; display: inline-block; margin-bottom: 8px; }
.fatigue-level.critical { background: var(--accent-red-dim); color: var(--accent-red); }
.fatigue-level.warning { background: var(--accent-yellow-dim); color: var(--accent-yellow); }
.fatigue-level.healthy { background: var(--accent-green-dim); color: var(--accent-green); }
.fatigue-name { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
.fatigue-stats { display: flex; gap: 20px; margin-bottom: 8px; }
.fatigue-stat { font-size: 12px; color: var(--text-muted); }
.fatigue-stat strong { color: var(--text-secondary); font-family: 'JetBrains Mono', monospace; }
.fatigue-note { font-size: 13px; color: var(--text-secondary); line-height: 1.5; white-space: pre-line; }
.fatigue-bar-bg { width: 120px; height: 6px; background: rgba(0,0,0,0.06); border-radius: 3px; overflow: hidden; margin-top: 4px; }
.fatigue-bar-fill { height: 100%; border-radius: 3px; }

/* ===== FORMAT ===== */
.format-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 24px; }
.format-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 24px; text-align: center; }
.format-icon { font-size: 28px; margin-bottom: 12px; }
.format-name { font-size: 14px; font-weight: 600; margin-bottom: 4px; }
.format-roas { font-family: 'JetBrains Mono', monospace; font-size: 24px; font-weight: 700; color: var(--accent-blue); margin-bottom: 12px; }
.format-details { display: flex; justify-content: center; gap: 16px; font-size: 12px; color: var(--text-muted); }

/* ===== FUNNEL ===== */
.funnel-wrapper { display: flex; flex-direction: column; }
.funnel-stage { background: var(--bg-card); border: 1px solid var(--border); padding: 28px 32px; display: grid; grid-template-columns: 200px 1fr; gap: 32px; align-items: center; }
.funnel-stage:first-child { border-radius: var(--radius-lg) var(--radius-lg) 0 0; }
.funnel-stage:last-child { border-radius: 0 0 var(--radius-lg) var(--radius-lg); }
.funnel-stage:not(:last-child) { border-bottom: none; }
.funnel-stage-name { font-size: 16px; font-weight: 700; }
.funnel-stage-sub { font-size: 12px; color: var(--text-muted); }
.funnel-pct { font-family: 'JetBrains Mono', monospace; font-size: 22px; font-weight: 700; }
.funnel-right { display: flex; gap: 32px; }
.funnel-metric-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.6px; color: var(--text-muted); }
.funnel-metric-value { font-family: 'JetBrains Mono', monospace; font-size: 15px; font-weight: 600; }
.funnel-bar { grid-column: 1 / -1; height: 4px; background: rgba(0,0,0,0.04); border-radius: 2px; overflow: hidden; margin-top: 8px; }
.funnel-bar-fill { height: 100%; border-radius: 2px; }

/* ===== ANALYSIS ===== */
.analysis-box { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 28px; margin-bottom: 24px; font-size: 15px; line-height: 1.8; color: var(--text-secondary); white-space: pre-line; }
.insight-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.insight-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 24px; position: relative; }
.insight-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; border-radius: var(--radius-lg) var(--radius-lg) 0 0; }
.insight-card.positive::before { background: var(--accent-green); }
.insight-card.negative::before { background: var(--accent-red); }
.insight-tag { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; display: inline-flex; align-items: center; gap: 6px; padding: 3px 10px; border-radius: 6px; }
.insight-tag.positive { color: var(--accent-green); background: var(--accent-green-dim); }
.insight-tag.negative { color: var(--accent-red); background: var(--accent-red-dim); }
.insight-title { font-size: 15px; font-weight: 600; margin-bottom: 8px; color: var(--text-primary); }
.insight-desc { font-size: 13px; color: var(--text-secondary); line-height: 1.6; white-space: pre-line; }
.impact-badge { margin-top: 12px; display: inline-flex; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); padding: 3px 8px; background: rgba(0,0,0,0.04); border-radius: 4px; }

/* ===== ACTIONS ===== */
.action-grid { display: grid; gap: 16px; }
.action-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 24px; display: flex; gap: 16px; align-items: flex-start; flex-wrap: wrap; }
.action-priority { writing-mode: vertical-lr; text-orientation: mixed; font-size: 10px; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; padding: 8px 4px; border-radius: 4px; text-align: center; }
.action-priority.high { color: var(--accent-red); background: var(--accent-red-dim); }
.action-priority.medium { color: var(--accent-yellow); background: var(--accent-yellow-dim); }
.action-priority.low { color: var(--accent-blue); background: var(--accent-blue-dim); }
.action-category { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); margin-bottom: 6px; }
.action-title { font-size: 15px; font-weight: 600; margin-bottom: 6px; color: var(--text-primary); }
.action-desc { font-size: 13px; color: var(--text-secondary); line-height: 1.5; white-space: pre-line; }
.action-expected { background: rgba(0,0,0,0.03); border-radius: var(--radius-sm); padding: 14px 18px; width: 100%; margin-top: 12px; }
.action-expected-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.6px; color: var(--text-muted); margin-bottom: 4px; }
.action-expected-value { font-size: 13px; color: var(--accent-green); font-weight: 500; line-height: 1.5; }

/* ===== PDF 전용 페이지 분리 (웹에서 안 보임) ===== */
.pdf-page-break { display: none; }

/* ===== FOOTER ===== */
.report-footer { margin-top: 64px; text-align: center; padding: 32px 0; border-top: 1px solid var(--border); color: var(--text-muted); font-size: 12px; }
.footer-brand { font-weight: 700; background: var(--gradient-brand); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

/* ===== PRINT / PDF ===== */
@media print {
  body { -webkit-print-color-adjust: exact; print-color-adjust: exact; font-size: 11px; }
  .report-container { max-width: 100%; padding: 0; }

  /* 카테고리별 페이지 분리 */
  .pdf-page-break { display: block; page-break-after: always; height: 0; margin: 0; }

  /* ── 전체 스케일 축소 ── */
  .section { margin-top: 12px; }
  .section-title { font-size: 16px; margin-bottom: 8px; }
  .section-label { font-size: 8px; margin-bottom: 4px; }

  /* ── 헤더 ── */
  .report-header::before { display: none !important; }
  .report-header { padding: 12px 0 8px; }
  .report-title {
    background: none !important;
    -webkit-background-clip: initial !important;
    -webkit-text-fill-color: var(--accent-blue) !important;
    background-clip: initial !important;
    color: var(--accent-blue) !important;
    font-size: 24px !important;
    margin-bottom: 4px !important;
  }
  .brand-badge { font-size: 9px; padding: 3px 10px; margin-bottom: 8px; }
  .report-period { font-size: 12px; }

  /* ── KPI 카드 ── */
  .kpi-grid { gap: 6px; }
  .kpi-card { padding: 8px 10px !important; border-radius: 6px; }
  .kpi-label { font-size: 8px !important; margin-bottom: 4px; }
  .kpi-value { font-size: 15px !important; white-space: nowrap; margin-bottom: 4px; }
  .kpi-change { font-size: 9px !important; padding: 1px 6px !important; }

  /* ── 차트 ── */
  .chart-container { padding: 12px; margin-bottom: 8px; }
  .chart-title { font-size: 12px; }
  .chart-header { margin-bottom: 8px; }
  .legend-item { font-size: 10px; }
  canvas#dailyChart { height: 140px !important; }

  /* ── 테이블 ── */
  .data-table { font-size: 10px; }
  .data-table thead th { padding: 6px 8px; font-size: 8px; }
  .data-table tbody td { padding: 4px 8px; font-size: 9px; }

  /* ── 캠페인 카드 ── */
  .campaign-card { padding: 14px 16px; }
  .campaign-name { font-size: 13px; }
  .campaign-objective { font-size: 10px; }
  .campaign-metric-label { font-size: 8px; }
  .campaign-metric-value { font-size: 12px; }
  .status-badge { font-size: 8px; padding: 3px 8px; }

  /* ── 피로도 카드 ── */
  .fatigue-card { padding: 16px; }
  .fatigue-name { font-size: 13px; }
  .fatigue-stat { font-size: 10px; }
  .fatigue-note { font-size: 11px; }
  .fatigue-level { font-size: 8px; }

  /* ── 포맷 카드 ── */
  .format-grid { gap: 10px; margin-top: 16px; }
  .format-card { padding: 16px; }
  .format-icon { font-size: 22px; margin-bottom: 8px; }
  .format-name { font-size: 12px; }
  .format-roas { font-size: 18px; margin-bottom: 8px; }
  .format-details { font-size: 10px; }

  /* ── 퍼널 ── */
  .funnel-stage { padding: 16px 20px; }
  .funnel-stage-name { font-size: 14px; }
  .funnel-pct { font-size: 18px; }
  .funnel-metric-label { font-size: 8px; }
  .funnel-metric-value { font-size: 12px; }

  /* ── 성과 분석 ── */
  .analysis-box { padding: 16px; font-size: 12px; line-height: 1.7; margin-bottom: 16px; }
  .insight-grid { gap: 10px; }
  .insight-card { padding: 14px; }
  .insight-tag { font-size: 8px; }
  .insight-title { font-size: 13px; }
  .insight-desc { font-size: 11px; }
  .impact-badge { font-size: 8px; }

  /* ── 추천 액션 ── */
  .action-card { padding: 14px 16px; gap: 14px; }
  .action-priority { font-size: 8px; }
  .action-category { font-size: 8px; }
  .action-title { font-size: 13px; }
  .action-desc { font-size: 11px; }
  .action-expected { padding: 10px 14px; min-width: 160px; }
  .action-expected-label { font-size: 8px; }
  .action-expected-value { font-size: 11px; }

  /* ── 푸터 ── */
  .report-footer { margin-top: 24px; padding: 16px 0; font-size: 10px; }

  /* ── 잘림 방지 ── */
  .section-title, .section-label, h3 { page-break-after: avoid; }
  .kpi-card, .campaign-card, .fatigue-card, .format-card { page-break-inside: avoid; }
  .insight-card, .action-card, .funnel-stage { page-break-inside: avoid; }
  .data-table-wrapper, .chart-container, .analysis-box { page-break-inside: avoid; }
}
</style>
</head>
<body>

<div class="report-container">

  <!-- ===== HEADER ===== -->
  <header class="report-header">
    <div class="brand-badge"><span class="dot"></span>{{ data.report_meta.brand_name }}</div>
    <h1 class="report-title">{{ '월간' if data.report_meta.get('report_type') == 'monthly' else '주간' }} 마케팅 리포트</h1>
    <p class="report-period">리포트 기간 <span>{{ data.report_meta.period_start }} ~ {{ data.report_meta.period_end }}</span></p>
  </header>

  <!-- ===== PAGE 1: KPI ===== -->
  <section class="section">
    <div class="section-label">Overview</div>
    <h2 class="section-title">전체 성과 요약</h2>
    <div class="kpi-grid">
      {% set kpis = [
        ("총 지출", data.kpi_summary.total_spend, "won", false),
        ("총 매출", data.kpi_summary.total_revenue, "won", true),
        ("ROAS", data.kpi_summary.roas, "x", false),
        ("CTR", data.kpi_summary.ctr, "%", false),
        ("전환", data.kpi_summary.conversions, "", false)
      ] %}
      {% for label, kpi, unit, highlight in kpis %}
      <div class="kpi-card{{ ' highlight' if highlight else '' }}">
        <div class="kpi-label">{{ label }}</div>
        <div class="kpi-value">
          {%- if unit == "won" -%}
            {{ "{:,.0f}".format(kpi.value) }}원
          {%- elif unit == "x" -%}
            {{ "%.2f"|format(kpi.value) }}x
          {%- elif unit == "%" -%}
            {{ "%.2f"|format(kpi.value) }}%
          {%- else -%}
            {{ "{:,.0f}".format(kpi.value) }}
          {%- endif -%}
        </div>
        <span class="kpi-change {{ 'up' if kpi.change_pct >= 0 else 'down' }}">
          {{ '↑' if kpi.change_pct >= 0 else '↓' }} {{ "%+.1f"|format(kpi.change_pct) }}%
        </span>
      </div>
      {% endfor %}
    </div>
  </section>

  <!-- 성과 추이 -->
  <section class="section">
    <div class="section-label">Daily Trend</div>
    <h2 class="section-title">성과 추이 ({{ '주별' if data.report_meta.get('report_type') == 'monthly' else '일별' }})</h2>

    <div class="chart-container">
      <div class="chart-header">
        <div class="chart-title">지출 vs 매출</div>
        <div class="chart-legend">
          <div class="legend-item"><div class="legend-dot" style="background:var(--accent-blue)"></div>지출</div>
          <div class="legend-item"><div class="legend-dot" style="background:var(--accent-purple)"></div>매출</div>
        </div>
      </div>
      <canvas id="dailyChart"></canvas>
    </div>

    <div class="data-table-wrapper">
      <table class="data-table">
        <thead><tr><th>날짜</th><th>지출</th><th>매출</th><th>ROAS</th><th>노출</th><th>클릭</th><th>전환</th></tr></thead>
        <tbody>
          {% for d in data.daily_data %}
          <tr>
            <td>{{ d.date }}</td>
            <td>{{ "{:,.0f}".format(d.spend) }}원</td>
            <td>{{ "{:,.0f}".format(d.revenue) }}원</td>
            <td>{{ "%.2f"|format(d.roas) }}x</td>
            <td>{{ "{:,.0f}".format(d.impressions) }}</td>
            <td>{{ "{:,.0f}".format(d.clicks) }}</td>
            <td>{{ d.conversions }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>


  <div class="pdf-page-break"></div>

  <!-- 캠페인별 성과 + 소재 -->
  <section class="section">
    <div class="section-label">Campaigns</div>
    <h2 class="section-title">캠페인별 성과</h2>

    <div class="campaign-grid">
      {% for c in data.campaigns %}
      <div class="campaign-card">
        <div>
          <div class="campaign-name">{{ c.name }}</div>
          <div class="campaign-objective">목표: {{ c.objective }}</div>
        </div>
        <div class="campaign-metrics">
          <div class="campaign-metric"><div class="campaign-metric-label">지출</div><div class="campaign-metric-value">{{ "{:,.0f}".format(c.spend) }}원</div></div>
          <div class="campaign-metric"><div class="campaign-metric-label">매출</div><div class="campaign-metric-value">{{ "{:,.0f}".format(c.revenue) }}원</div></div>
          <div class="campaign-metric"><div class="campaign-metric-label">ROAS</div><div class="campaign-metric-value" {% if c.roas >= 4.0 %}style="color:var(--accent-green)"{% endif %}>{{ "%.2f"|format(c.roas) }}x</div></div>
          <div class="campaign-metric"><div class="campaign-metric-label">CTR</div><div class="campaign-metric-value">{{ "%.1f"|format(c.ctr) }}%</div></div>
          <div class="campaign-metric"><div class="campaign-metric-label">전환</div><div class="campaign-metric-value">{{ c.conversions }}</div></div>
          <span class="status-badge {{ c.status|lower }}">{{ c.status }}</span>
        </div>
      </div>
      {% endfor %}
    </div>

    <h3 class="section-title" style="margin-top:32px;font-size:18px;">소재별 성과 TOP 5</h3>
    <div class="data-table-wrapper">
      <table class="data-table">
        <thead><tr><th>소재</th><th>포맷</th><th>지출</th><th>매출</th><th>ROAS</th><th>CTR</th><th>클릭</th><th>전환</th></tr></thead>
        <tbody>
          {% for cr in data.creatives_top5 %}
          <tr>
            <td>{{ cr.name }}</td>
            <td style="text-align:right">{{ cr.format }}</td>
            <td>{{ "{:,.0f}".format(cr.spend) }}원</td>
            <td>{{ "{:,.0f}".format(cr.revenue) }}원</td>
            <td {% if cr.roas >= 5.0 %}style="color:var(--accent-green)"{% elif cr.roas < 3.0 %}style="color:var(--accent-red)"{% endif %}>{{ "%.2f"|format(cr.roas) }}x</td>
            <td>{{ "%.1f"|format(cr.ctr) }}%</td>
            <td>{{ "{:,.0f}".format(cr.clicks) }}</td>
            <td>{{ cr.conversions }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>


  <div class="pdf-page-break"></div>

  <!-- 소재 피로도 + 포맷 -->
  <section class="section">
    <div class="section-label">Creative Fatigue</div>
    <h2 class="section-title">소재 피로도 지수</h2>

    <div class="fatigue-grid">
      {% for f in data.creative_fatigue %}
      <div class="fatigue-card">
        <div class="fatigue-indicator {{ f.level|lower }}"></div>
        <div style="flex:1">
          <span class="fatigue-level {{ f.level|lower }}">{{ f.level }}</span>
          <div class="fatigue-name">{{ f.name }} <span style="color:var(--text-muted);font-size:12px;font-weight:400">({{ f.format_type }})</span></div>
          <div class="fatigue-stats">
            <span class="fatigue-stat">피로도: <strong>{{ f.fatigue_score }}/100</strong></span>
            <span class="fatigue-stat">Frequency: <strong>{{ f.frequency }}</strong></span>
            <span class="fatigue-stat">CTR: <strong>{{ f.ctr }}%</strong></span>
            <span class="fatigue-stat">활성일: <strong>{{ f.active_days }}일</strong></span>
          </div>
          {% set bar_color = 'var(--accent-red)' if f.level == 'CRITICAL' else ('var(--accent-yellow)' if f.level == 'WARNING' else 'var(--accent-green)') %}
          <div class="fatigue-bar-bg"><div class="fatigue-bar-fill" style="width:{{ f.fatigue_score }}%;background:{{ bar_color }}"></div></div>
          <p class="fatigue-note" style="margin-top:10px">{{ f.note }}</p>
        </div>
      </div>
      {% endfor %}
    </div>

    <h3 class="section-title" style="margin-top:40px;font-size:18px;">소재 포맷별 성과</h3>
    <div class="format-grid">
      {% set format_icons = {"이미지": "🖼", "동영상": "🎬", "카루셀": "🎠"} %}
      {% for fp in data.format_performance %}
      <div class="format-card">
        <div class="format-icon">{{ format_icons.get(fp.format, "📊") }}</div>
        <div class="format-name">{{ fp.format }}</div>
        <div class="format-roas">{{ "%.2f"|format(fp.roas) }}x</div>
        <div class="format-details">
          <span>소재 {{ fp.count }}개</span>
          <span>CTR {{ fp.ctr }}%</span>
          <span>Freq {{ fp.frequency }}</span>
        </div>
        {% if fp.thru_play_rate %}
        <div style="margin-top:8px;font-size:11px;color:var(--accent-purple)">완전재생 {{ fp.thru_play_rate }}%</div>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </section>


  <div class="pdf-page-break"></div>

  <!-- 퍼널 -->
  <section class="section">
    <div class="section-label">Funnel</div>
    <h2 class="section-title">퍼널 단계별 성과</h2>

    <div class="funnel-wrapper">
      {% set funnel_colors = ["var(--accent-blue)", "var(--text-muted)", "var(--accent-green)"] %}
      {% for i, f in enumerate(data.funnel) %}
      <div class="funnel-stage">
        <div>
          <div class="funnel-stage-name" style="color:{{ funnel_colors[i] }}">{{ f.stage }}</div>
          <div class="funnel-stage-sub">{{ f.campaigns_count }}개 캠페인</div>
          <div class="funnel-pct" style="color:{{ funnel_colors[i] }}">{{ "%.1f"|format(f.pct) }}%</div>
        </div>
        <div class="funnel-right">
          <div class="funnel-metric"><div class="funnel-metric-label">지출</div><div class="funnel-metric-value" {% if f.spend == 0 %}style="color:var(--text-muted)"{% endif %}>{{ "{:,.0f}".format(f.spend) }}원</div></div>
          <div class="funnel-metric"><div class="funnel-metric-label">전환</div><div class="funnel-metric-value" {% if f.conversions == 0 %}style="color:var(--text-muted)"{% endif %}>{{ f.conversions }}건</div></div>
          <div class="funnel-metric"><div class="funnel-metric-label">ROAS</div><div class="funnel-metric-value" {% if f.roas == 0 %}style="color:var(--text-muted)"{% endif %}>{{ "%.2f"|format(f.roas) }}x</div></div>
          <div class="funnel-metric"><div class="funnel-metric-label">CTR</div><div class="funnel-metric-value" {% if f.ctr == 0 %}style="color:var(--text-muted)"{% endif %}>{{ "%.1f"|format(f.ctr) }}%</div></div>
        </div>
        <div class="funnel-bar"><div class="funnel-bar-fill" style="width:{{ f.pct }}%;background:{{ funnel_colors[i] }}"></div></div>
      </div>
      {% endfor %}
    </div>
  </section>

  <!-- 성과 분석 -->
  <section class="section">
    <div class="section-label">Analysis</div>
    <h2 class="section-title">성과 분석</h2>

    <div class="analysis-box">{{ data.analysis.summary }}</div>

    <div class="insight-grid">
      {% for p in data.analysis.positives %}
      <div class="insight-card positive">
        <div class="insight-tag positive">✓ 잘된 점</div>
        <div class="insight-title">{{ p.title }}</div>
        <div class="insight-desc">{{ p.desc }}</div>
        <div class="impact-badge">영향도: {{ p.impact }}</div>
      </div>
      {% endfor %}
      {% for n in data.analysis.negatives %}
      <div class="insight-card negative">
        <div class="insight-tag negative">✕ 개선 필요</div>
        <div class="insight-title">{{ n.title }}</div>
        <div class="insight-desc">{{ n.desc }}</div>
        <div class="impact-badge">영향도: {{ n.impact }}</div>
      </div>
      {% endfor %}
    </div>
  </section>


  <div class="pdf-page-break"></div>

  <!-- 추천 액션 -->
  <section class="section">
    <div class="section-label">Next Steps</div>
    <h2 class="section-title">추천 액션</h2>

    <div class="action-grid">
      {% for a in data.actions %}
      <div class="action-card">
        <div class="action-priority {{ a.priority|lower }}">{{ a.priority if a.priority != 'MEDIUM' else 'MED' }}</div>
        <div style="flex:1;min-width:0">
          <div class="action-category">{{ a.category }}</div>
          <div class="action-title">{{ a.title }}</div>
          <div class="action-desc">{{ a.desc }}</div>
          <div class="action-expected">
            <div class="action-expected-label">예상 효과</div>
            <div class="action-expected-value">{{ a.expected }}</div>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="report-footer">
    <p>생성일: {{ data.report_meta.generated_at }}</p>
    <p style="margin-top:4px;font-weight:700;color:var(--accent-blue)">바투 AI 마케팅</p>
  </footer>

</div>

<script>
const ctx = document.getElementById('dailyChart').getContext('2d');
const g1 = ctx.createLinearGradient(0,0,0,280);
g1.addColorStop(0,'rgba(59,111,224,0.18)'); g1.addColorStop(1,'rgba(59,111,224,0)');
const g2 = ctx.createLinearGradient(0,0,0,280);
g2.addColorStop(0,'rgba(124,92,219,0.18)'); g2.addColorStop(1,'rgba(124,92,219,0)');

const dailyData = {{ daily_json|safe }};

new Chart(ctx, {
  type: 'line',
  data: {
    labels: dailyData.map(d => d.date),
    datasets: [
      {
        label: '지출', data: dailyData.map(d => d.spend),
        borderColor: '#3B6FE0', backgroundColor: g1, borderWidth: 2.5,
        fill: true, tension: 0.4, pointRadius: 4,
        pointBackgroundColor: '#3B6FE0', pointBorderColor: '#FFFFFF', pointBorderWidth: 2,
      },
      {
        label: '매출', data: dailyData.map(d => d.revenue),
        borderColor: '#7C5CDB', backgroundColor: g2, borderWidth: 2.5,
        fill: true, tension: 0.4, pointRadius: 4,
        pointBackgroundColor: '#7C5CDB', pointBorderColor: '#FFFFFF', pointBorderWidth: 2,
      }
    ]
  },
  options: {
    responsive: true, maintainAspectRatio: false,
    interaction: { intersect: false, mode: 'index' },
    plugins: {
      legend: { display: false },
      tooltip: {
        backgroundColor: '#FFFFFF', borderColor: '#E2E4ED', borderWidth: 1,
        titleColor: '#1A1D2E', bodyColor: '#5A5E76', padding: 12, cornerRadius: 8,
        callbacks: { label: ctx => ctx.dataset.label + ': ' + ctx.parsed.y.toLocaleString() + '원' }
      }
    },
    scales: {
      x: { grid: { color: 'rgba(0,0,0,0.07)', drawBorder: false }, ticks: { color: '#8B8FA8', font: { family: 'JetBrains Mono', size: 11 } } },
      y: { grid: { color: 'rgba(0,0,0,0.07)', drawBorder: false }, ticks: { color: '#8B8FA8', font: { family: 'JetBrains Mono', size: 11 }, callback: v => (v/10000).toFixed(0)+'만' } }
    }
  }
});
</script>
</body>
</html>
