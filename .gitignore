# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results
/tests/e2e/storage-state.json
/tests/performance/results/*.json
.stryker-tmp/
/reports/mutation/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# auth state (Playwright session for demo recording)
.auth-state.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (NEVER commit secrets!)
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# secrets & credentials
*.secret
*.secrets
*credentials*.json
*service-account*.json
*.key
!*.key.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
.playwright-mcp/


# kombai
.kombai/

# screenshots
landing-*.png
competitors-page.png
portfolio-page.png

# agent internal state (workflows/skills는 IDE가 스캔해야 하므로 제외하지 않음)
# .agent/ 전체 대신 하위만 선택적 무시
.sisyphus/
.claude/
.openchrome/
docs/meta-app-review/recordings/

# git worktrees for parallel agent work
.worktrees/
__pycache__/
